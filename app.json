{
  "expo": {
    "name": "OurHome",
    "slug": "ourhome-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "ourhome",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ourhome.app"
    },
    "android": {
      "package": "com.ourhome.app",
      "adaptiveIcon": {
        "backgroundColor": "#FDF6EE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép OurHome truy cập ảnh để xác nhận hoàn thành việc nhà."
        }
      ],
      "expo-splash-screen",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
